def list_comp(eps, a,b, numcp,tmax, kmax, rmax):
    ###Only returning the three lists
    delta = (b-a)/numcp
    rancp = srange(a,b,delta)
    ### A list of Three lists
    LisCom = [[], [], []]
    for cp in rancp:
        (Cmin, [t_best, k_best, r_best], rangeEps) = MNFSAComplexity_at_cp(eps,cp,tmax, kmax, rmax)
        #print([t_best, k_best, r_best], labels[rangeEps])
        LisCom[rangeEps] += [(cp, Cmin)]
    return LisCom

def plot_comp_total(eps, num):
    ###small epsilon
    ##small cp [0.2,1] put tmax = 20, rmax = kmax= 1
    ### middle cp 1 [1, 2] put tmax = 3 rmax = 3, kmax = 3 with extra number of points
    ### middle cp 2 [2, 4] put tmax = 2 rmax = 3, kmax = 3
    ### large cp [4,10] put tmax = 2 rmax = 7, kmax = 1
    G = Graphics()
    LisCompT = [[], [], []]
    LisComp1 = list_comp(eps, 0.2,1, num,20,1,1)
    LisComp2a = list_comp(eps, 1, 2, 2*num,3,3,3)
    LisComp2b = list_comp(eps, 2,4, num,2,3,3)
    LisComp3 = list_comp(eps, 4, 10, num,2,7,1)
    for i in range(0,3):
        LisCompT[i] += LisComp1[i]
        LisCompT[i] += LisComp2a[i]
        LisCompT[i] += LisComp2b[i]
        LisCompT[i] += LisComp3[i]
    G = Graphics()
    for i in range(0,3):
        G += points(LisCompT[i], color = colors[i], legend_label = 'eps= '+ str(eps.n(11))+', '+labels[i], size = 3)
        #G += line(LisCompT[i], color = colors[i], legend_label = 'eps= '+ str(eps.n(11))+', '+labels[i])
    return G

