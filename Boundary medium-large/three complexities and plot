###Large epsilon
var('t,k,r,eps,cp')
sq(t,k,r,eps,cp) = r*((eps + 2)*r + (eps + 1))/(9*k^2*cp^2*t^2) + k*cp*(t-1)/(3*(r+1))
compepsL(t,k,r,eps,cp) = ((r+1)*eps + 3*r+1)/(3*k*cp*t) + 2*sqrt(sq) 
## plus p1+ cV
c = (2*r/(eps+1) + 1)^2 - 2*r^2 - 3*r - 1 + eps*(r^2 + r)
sqr = k*(t-1)*(eps-1)^2*cp^3/(3*(r+1)*(eps+1)^2) + c/(9*k^2*t^2)
term = ((2*r + eps + 1)/(eps +1) - (r+1)*(eps+1))/(3*cp*k*t)
p1cV = term + sqrt(sqr)/cp
fcheck(t,k,r,eps,cp) = p1cV

###Medium epsilon
###Formula for complexity 
cff = [(-k*t*cp + k*cp)/(3*r*eps + 3*eps), (-r*eps^2 - 2*r*eps - eps^2 - r - eps)/(3*k*t*eps*cp), 1]
solcB = (-cff[1] + sqrt(cff[1]^2 - 4*cff[0]))/2
compepsM(t,k,r, eps, cp) = (1+eps)*solcB

##Small epsilon

R.<t,k,r,eps> = PolynomialRing(QQ)
P = R.fraction_field() 
### Set p1 + cV = 0 and minimize sieving t*cA
M.<cB, cA,cp> = PolynomialRing(P, order='lex')
p1 = -cA*(r+1)/(3*k*cB*cp)
cV = -p1
p2 = -(cA*r/(k*cp) + (t-1)*k*cp/(r+1))/(3*(cB - cV))
c = numerator(p1 + p2 + cV +t*cA - cB)
#L = t*cA + l1*c, the derivative of cA is only used to solve for l1
eq1 = derivative(c,cB)
I = ideal([eq1,c])
B = I.groebner_basis()
### well defined as long as cp \not= 0
eqcA = B[-1]
###This polynomial cannot be used if cp^3 = (81*r^3 + 234*r^2 + 225*r + 72)/(k^3*t^3 + k^3*t^2) = 9*(r+1)^2*(9*r+8)/(k^3*t^2*(t+1))
relcBcA(cB) = B[-2]
valcB = solve(relcBcA, cB, solution_dict=True)[0][cB]
## return cV too, so can compare cB > cV in the end
#valcV(r,k,cA,cB,cp) = cV
rels(t,k,r,cp) = [eqcA, valcB, cV]

def MNFSAComplexitySmall_at_RKTcp(t,k,r,cp):
    [eqcA_eval, valcB_eval, valcV_eval] = rels(t,k,r,cp) 
    pol(cA) = eqcA_eval
    valcB(cA) = valcB_eval
    valcV(cA, cB) = valcV_eval
    R1.<x> = PolynomialRing(RR)
    rootsA = (R1(pol(x))).roots()
    ### iterate on all positive roots of and produce the corresponding value of cB
    ### check that it is a correct value for the complexity: compute cV and compare with cB
    Cmin = 1e6
    #Return the rest of parameters if needed
    cont = [0,0,0]
    for (valcA,m) in rootsA:
        if valcA > 0 and t*valcA < Cmin: ## we compute the rest of continuous parameters, instead of checking if they are all positive and if cB > cV, we plot them at the end
            valcB = valcB(valcA)
            valcV = valcV(valcA, valcB) ##it is positive if both cA and cB are positive
            Cmin = t*valcA
            cont = [valcA, valcB, valcV]
    return (Cmin, cont)

