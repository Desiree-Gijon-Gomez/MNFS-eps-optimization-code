labels = ['small', 'medium', 'large']
colors = ['green', 'black', 'red']

def minim_with_index(lis):
    Cmin = 1e6
    index_min = len(lis)
    for i in range(0,len(lis)):
        if lis[i] < Cmin:
            Cmin = lis[i]
            index_min = i
    return (Cmin, index_min)

def MNFSAComplexity_at_cp(eps,cp,tmax, rmax, kmax):
    Cmin = 1e6
    [t_best, k_best, r_best] = [0,0,0]
    rangeEps = 3 ## For recollecting if it was the strategy with small, medium or large epsilon
    for t in range(2, tmax + 1):
        for k in range(1, kmax + 1):
            for r in range(k, rmax + 1):
                compL = compepsL(t,k,r,eps,cp) + max_symbolic(0, fcheck(t,k,r,eps,cp))
                compM = compepsM(t,k,r,eps,cp)
                (Siev, cont) = MNFSAComplexitySmall_at_RKTcp(t,k,r,cp)
                compS = max_symbolic(Siev, (1+eps)*cont[1])
                ### Minimum with the correct label
                #print(compS, compM, compL)
                (C, i) = minim_with_index([compS, compM, compL])
                if C < Cmin:
                    Cmin = C
                    [t_best, k_best, r_best] = [t,k,r]
                    rangeEps  = i
    return (Cmin, [t_best, k_best, r_best], rangeEps)

def plot_comp(eps, a,b, numcp,tmax, kmax, rmax):
    delta = (b-a)/numcp
    rancp = srange(a,b,delta)
    ### A list of Three lists
    LisCom = [[], [], []]
    for cp in rancp:
        (Cmin, [t_best, k_best, r_best], rangeEps) = MNFSAComplexity_at_cp(eps,cp,tmax, kmax, rmax)
        #print([t_best, k_best, r_best], labels[rangeEps])
        LisCom[rangeEps] += [(cp, Cmin)]
    G = Graphics()
    for i in range(0,3):
        G += points(LisCom[i], color = colors[i], legend_label = labels[i], size = 3)
    return G

