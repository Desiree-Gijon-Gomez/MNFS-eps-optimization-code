##Small epsilon

R.<t,k,r> = PolynomialRing(QQ)
P = R.fraction_field() 
### Set p1 + cV = 0 and minimize sieving t*cA
M.<cB, cA,cp> = PolynomialRing(P, order='lex')
p1 = -cA*(r+1)/(3*k*cB*cp)
cV = -p1
p2 = -(cA*r/(k*cp) + (t-1)*k*cp/(r+1))/(3*(cB - cV))
c = numerator(p1 + p2 + cV +t*cA - cB)
#L = t*cA + l1*c, the derivative of cA is only used to solve for l1
eq1 = derivative(c,cB)
I = ideal([eq1,c])
B = I.groebner_basis()
### well defined as long as cp \not= 0
eqcA = B[-1]
###This polynomial cannot be used if cp^3 = (81*r^3 + 234*r^2 + 225*r + 72)/(k^3*t^3 + k^3*t^2) = 9*(r+1)^2*(9*r+8)/(k^3*t^2*(t+1))
relcBcA(cB) = B[-2]
valcB = solve(relcBcA, cB, solution_dict=True)[0][cB]
## return cV too, so can compare cB > cV in the end
#valcV(r,k,cA,cB,cp) = cV
rels(t,k,r,cp) = [eqcA, valcB, cV]

def MNFSAComplexitySmall_at_RKTcp(t,k,r,cp):
    [eqcA_eval, valcB_eval, valcV_eval] = rels(t,k,r,cp) 
    pol(cA) = eqcA_eval
    valcB(cA) = valcB_eval
    valcV(cA, cB) = valcV_eval
    R1.<x> = PolynomialRing(RR)
    rootsA = (R1(pol(x))).roots()
    ### iterate on all positive roots of and produce the corresponding value of cB
    ### check that it is a correct value for the complexity: compute cV and compare with cB
    Cmin = 1e6
    #Return the rest of parameters if needed
    param = [0,0,0]
    for (valcA,m) in rootsA:
        if valcA > 0 and t*valcA < Cmin: ## we compute the rest of parameters, instead of checking if they are all positive and if cB > cV, we plot them at the end
            valcB = valcB(valcA)
            valcV = valcV(valcA, valcB) ##it is positive if both cA and cB are positive
            Cmin = t*valcA
            param = [valcA, valcB, valcV]
    return (Cmin, param)

