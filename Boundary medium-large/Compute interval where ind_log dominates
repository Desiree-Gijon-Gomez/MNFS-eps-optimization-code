### Find the comp = ind_log by bipartition

## there are two values where comp = ind_log, one in [1,2] and another in [2,3]
ind_log = ((9/2)^(1/3))
def partition(a,b):
    lis = [a, (a+b)/2, b]
    lisfun =[]
    for cp in lis:
        #print(cp)
        comp = MNFSAComplexity_at_cp(cp,3,3,3)
        fun = comp - ind_log
        lisfun += [fun]
    for i in range(0,2):
        if lisfun[i]*lisfun[i+1] < 0:
            ## If there is a change of sign, means the zero is in that interval
            ext1 = lis[i]
            ext2 = lis[i+1]
    return (ext1, ext2)
    
