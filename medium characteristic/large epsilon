def plot_check_constrains():
    # recall p1 = -cA*(r+1)/(3*k*cB)
    rels_eval(eps) = rels(1,1,eps)
    cB_val = rels_eval[0]
    ct_val = rels_eval[1]
    cV_val = rels_eval[2]
    cA_val = (1+eps)*cB_val/ct_val
    p1_eval = -cA_val*2/(3*cB_val)
    return plot(cV_val + p1_eval, (eps, 0,1))
plot_check_constrains() 

def compute_eps(r,k):
    # recall p1 = -cA*(r+1)/(3*k*cB)
    rels_eval(eps) = rels(r,k,eps)
    cB_val = rels_eval[0]
    ct_val = rels_eval[1]
    cV_val = rels_eval[2]
    cA_val = (1+eps)*cB_val/ct_val
    p1_eval = -cA_val*(r+1)/(3*k*cB_val)
    eps_valid = find_root(cV_val + p1_eval, 0,1)
    return eps_valid

