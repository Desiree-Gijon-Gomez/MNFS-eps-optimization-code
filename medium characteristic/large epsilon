##minimizing complexity, plotting for several values of r

def random_color():
    l = len(colors)
    R = Integers(l)
    s = R.random_element()
    return sorted(colors)[s]

def plot_minimize_complexity(rmax):
    #observe that k does not appear in the expression of cB
    G  =Graphics()
    for r in range(1,rmax):
        s = random_color()
        comp = (1+eps)*rels(r,1,eps)[0]
        G +=plot(comp, (eps, 0,1), color=s, legend_label = r)
    return G.show()

