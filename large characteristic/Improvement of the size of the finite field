##Recommended size of security 

#bitsec = 2048

def find_recomm_size(eps,bitsec):
    logQsec = bitsec*log(2)
    ll(const,x) = const*(x^(1/3))*((log(x))^(2/3))
    Costsec = ll(Cahora, logQsec)
    Ceps = comp_total(eps)
    fun(x) = ll(Ceps,x)
    #plot(fun - Costsec, 1e2, 3e3)
    x_0 = find_root(fun-Costsec, 1e2,3e3)
    ## want Q'= > 2^(*) so return = log(Q')/log(2)
    return x_0/log(2)

##This return logQeps for the new cost, to garantee same level of security
##In terms of porcentual improvement, if Qeps = kQ, then log(k) = log(Qeps)- log(Q), and want 100k
##actually want 100*(k-1)
def plot_improvement(ran, bitsec):
    lis = []
    for eps in ran:
        xeps = find_recomm_size(eps,bitsec)
        #print((eps,xeps))
        lis += [(eps, xeps)]
    #return plot(points(lis))
    return lis

def plot_improvement_relative(ran,bitsec):
    lis = []
    for eps in ran:
        xeps = find_recomm_size(eps, bitsec)
        keps = (xeps-bitsec)/bitsec
        #print((eps,keps))
        lis += [(eps, keps)]
    #return plot(points(lis))
    return lis

def comparison(ran):
    bits = [2048, 3072]
    lis1 = plot_improvement(ran,bits[0])
